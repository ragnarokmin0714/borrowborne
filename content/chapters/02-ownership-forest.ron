// Ownership Forest — move semantics and borrowing.
//
// Trial assertions MUST carry a "TRIAL: …" message: the runner uses the
// marker to tell a failed trial apart from a player panic (permadeath).
(
    id: "ownership-forest",
    name: "Ownership Forest",
    tagline: "Here, what you give away is gone. The trees remember every move.",
    puzzles: [
        (
            id: "of-01-the-kept-key",
            title: "The Kept Key",
            scene: "A gatekeeper blocks the forest path.\n\n\"Hand me your key and I shall inspect it,\" it rasps — but whatever you hand this creature, it KEEPS. You must let it look at the key without giving the key away, or you will have nothing left to open the gate with.\n\nMend the spell so the gatekeeper only borrows.",
            concepts: [Move, Borrow],
            starter_code: r#"// The gatekeeper takes ownership of the key… and keeps it.
fn inspect(key: String) -> bool {
    key == "rusty-key"
}

fn open_gate(key: String) -> bool {
    let approved = inspect(key);
    // The key was moved into `inspect` — it is gone. This does not compile.
    approved && key == "rusty-key"
}
"#,
            trial: r#"assert!(
    open_gate(String::from("rusty-key")),
    "TRIAL: the gate stayed shut for the rightful key"
);
assert!(
    !open_gate(String::from("bent-key")),
    "TRIAL: the gate opened for a counterfeit key"
);"#,
            solution: r#"fn inspect(key: &str) -> bool {
    key == "rusty-key"
}

fn open_gate(key: String) -> bool {
    let approved = inspect(&key);
    approved && key == "rusty-key"
}
"#,
        ),
        (
            id: "of-02-the-twin-scribes",
            title: "The Twin Scribes",
            scene: "Two scribes must each measure the same ancient scroll.\n\nThe first scribe takes the scroll to measure it — and the scroll is gone. The second scribe finds only empty air.\n\nLet both scribes read the scroll without consuming it.",
            concepts: [Borrow],
            starter_code: r#"fn measure(scroll: String) -> usize {
    scroll.len()
}

fn measure_twice(scroll: String) -> (usize, usize) {
    let first = measure(scroll);
    // The scroll was moved into the first measurement. Nothing remains.
    let second = measure(scroll);
    (first, second)
}
"#,
            trial: r#"assert_eq!(
    measure_twice(String::from("ancient")),
    (7, 7),
    "TRIAL: the scribes disagree about the scroll"
);"#,
            solution: r#"fn measure(scroll: &String) -> usize {
    scroll.len()
}

fn measure_twice(scroll: String) -> (usize, usize) {
    let first = measure(&scroll);
    let second = measure(&scroll);
    (first, second)
}
"#,
        ),
        (
            id: "of-03-the-whetstone",
            title: "The Whetstone",
            scene: "A blade lies on the forest anvil. The whetstone can sharpen it — but only if it is allowed to CHANGE the blade.\n\nA shared glance (`&`) lets you look; only an exclusive grip (`&mut`) lets you alter. And a thing must itself be willing to change (`mut`) before any grip can bend it.\n\nGrant the whetstone its exclusive grip.",
            concepts: [MutBorrow, Mutability],
            starter_code: r#"fn sharpen(blade: &String) {
    // A shared borrow may look, but never alter. This does not compile.
    blade.push_str(" +1");
}

fn forge() -> String {
    let blade = String::from("iron sword");
    sharpen(&blade);
    blade
}
"#,
            trial: r#"assert_eq!(
    forge(),
    "iron sword +1",
    "TRIAL: the blade left the anvil dull"
);"#,
            solution: r#"fn sharpen(blade: &mut String) {
    blade.push_str(" +1");
}

fn forge() -> String {
    let mut blade = String::from("iron sword");
    sharpen(&mut blade);
    blade
}
"#,
        ),
        (
            id: "of-04-the-cost-of-twins",
            title: "The Cost of Twins",
            scene: "Twin shrines flank the deep path, and each demands a bone-ash key — demands it WHOLE, to devour. No borrowing appeases them; the offering must be owned.\n\nYou hold one key. The forest offers a dark bargain: a perfect twin can be forged, at a price paid in effort. Some call it wasteful. Tonight, it is simply correct.\n\nForge the twin. Feed both shrines.",
            concepts: [Move],
            starter_code: r#"fn consume(key: String) -> usize {
    // The shrine devours the key whole. It will not accept a borrow.
    key.len()
}

fn twin_offering(key: String) -> (usize, usize) {
    let west = consume(key);
    // The key went into the west shrine. Nothing remains for the east —
    // unless a twin is forged before the first offering.
    let east = consume(key);
    (west, east)
}
"#,
            trial: r#"assert_eq!(
    twin_offering(String::from("bone-ash")),
    (8, 8),
    "TRIAL: one shrine went unfed"
);"#,
            hints: [
                "When a borrow is not allowed and ownership is demanded twice, duplication is the honest answer.",
                "`.clone()` forges an owned twin — spend it on the FIRST offering, keep the original for the second.",
                "`let west = consume(key.clone());` then `let east = consume(key);`",
            ],
            solution: r#"fn consume(key: String) -> usize {
    key.len()
}

fn twin_offering(key: String) -> (usize, usize) {
    let west = consume(key.clone());
    let east = consume(key);
    (west, east)
}
"#,
        ),
        (
            id: "of-05-the-loan-note",
            title: "The Loan Note",
            scene: "The forest archivist reads loan notes — thin slices of text, `&str`. You arrive clutching a whole scroll, a `String`, heavy with ink you own.\n\nThe archivist will not take the scroll. \"I read; I do not keep. Show me the writing, not the vessel.\"\n\nOffer a view of what you hold.",
            concepts: [Borrow],
            starter_code: r#"fn read_inscription(note: &str) -> usize {
    note.len()
}

fn archive() -> usize {
    let scroll: String = String::from("fear the old blood");
    // The archivist reads &str; you hold a String. The vessel is not
    // the writing — offer a view of it instead.
    read_inscription(scroll)
}
"#,
            trial: r#"assert_eq!(
    archive(),
    18,
    "TRIAL: the inscription went unread"
);"#,
            hints: [
                "A `String` owns its text; a `&str` merely looks at text. Functions that only read usually ask for `&str`.",
                "You cannot hand over the vessel — lend a view. One character changes everything.",
                "`read_inscription(&scroll)` — a `&String` softens into `&str` on its own (deref coercion).",
            ],
            solution: r#"fn read_inscription(note: &str) -> usize {
    note.len()
}

fn archive() -> usize {
    let scroll: String = String::from("fear the old blood");
    read_inscription(&scroll)
}
"#,
        ),
    ],
)
