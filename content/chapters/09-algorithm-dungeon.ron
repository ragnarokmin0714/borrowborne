// Algorithm Dungeon — the hardcore-only vault of complexity.
//
// Only the Unforgiven descend here. Every puzzle but the reversal is
// TLE-ARMORED: the starter is CORRECT but too slow — a naive O(n^2) or
// O(n*k) that the trial floods until it blows past the 5 s budget. The
// canonical solution is the same answer in better complexity, and it
// finishes with room to spare.
//
// Trial assertions MUST carry a "TRIAL: …" message.
(
    id: "algorithm-dungeon",
    name: "Algorithm Dungeon",
    tagline: "Correct is not enough here. Only the fast leave alive.",
    hardcore_only: true,
    puzzles: [
        (
            id: "ad-01-the-paired-sigils",
            title: "The Paired Sigils",
            scene: "The vault door opens only if two sigil-values in the pile sum to the seal. The spell below checks every pair — correct, and doomed: with a hundred thousand sigils that is ten billion comparisons, and the night is five seconds long.\n\nRemember each value you have seen in a set; for each new one, ask whether its partner (seal − value) is already there. One pass, not two loops.",
            concepts: [Algorithms, Collections],
            starter_code: r#"fn has_pair(values: &[i64], seal: i64) -> bool {
    // Correct — and O(n^2). Every pair is compared; the flood of
    // 120_000 values makes that ~7 billion checks. It will NOT finish.
    // A HashSet of seen values answers each partner in one look.
    for i in 0..values.len() {
        for j in (i + 1)..values.len() {
            if values[i] + values[j] == seal {
                return true;
            }
        }
    }
    false
}
"#,
            trial: r#"assert!(has_pair(&[2, 7, 11, 15], 9), "TRIAL: an obvious pair was missed");
assert!(!has_pair(&[1, 2, 3], 100), "TRIAL: a pair was invented");
// The flood: 120_000 even values, an odd seal — no two evens can sum
// to it, so the naive scan must compare every pair and time out.
let flood: Vec<i64> = (0..120_000).map(|x| x * 2).collect();
assert!(!has_pair(&flood, 1), "TRIAL: two evens cannot sum to an odd seal");"#,
            hints: [
                "The answer is right; the complexity is wrong. Trade the inner loop for a lookup.",
                "Walk once, remembering values in a `HashSet`. For each value, check whether `seal - value` was already seen.",
                "let mut seen = HashSet::new(); for &v in values { if seen.contains(&(seal - v)) { return true; } seen.insert(v); } false",
            ],
            toolbox: [
                "HashSet",
                ".contains() / .insert()",
                "seal - value (the partner)",
            ],
            solution: r#"use std::collections::HashSet;

fn has_pair(values: &[i64], seal: i64) -> bool {
    let mut seen = HashSet::new();
    for &v in values {
        if seen.contains(&(seal - v)) {
            return true;
        }
        seen.insert(v);
    }
    false
}
"#,
        ),
        (
            id: "ad-02-the-sliding-ward",
            title: "The Sliding Ward",
            scene: "A ward of `k` consecutive stones must be charged, and you want the strongest such stretch — the maximum sum of any `k`-in-a-row. The spell re-sums every window from scratch: with a long corridor and a wide ward that is `n × k` additions, and it times out.\n\nSlide the window instead: sum the first `k`, then for each step add the entering stone and subtract the leaving one. Each step is O(1); the whole corridor is one pass.",
            concepts: [Algorithms],
            starter_code: r#"fn strongest_ward(stones: &[i64], k: usize) -> i64 {
    // Correct — and O(n*k): each window is summed from scratch. The
    // trial floods 200_000 stones with k=100_000, ~10 billion adds.
    // Slide the window: add the entering stone, drop the leaving one.
    let mut best = i64::MIN;
    for start in 0..=(stones.len() - k) {
        let sum: i64 = stones[start..start + k].iter().sum();
        best = best.max(sum);
    }
    best
}
"#,
            trial: r#"assert_eq!(strongest_ward(&[1, 2, 3, 4, 5], 2), 9, "TRIAL: the strongest pair was misread");
assert_eq!(strongest_ward(&[4, -1, 2, 1], 2), 3, "TRIAL: a window summed wrong");
// The flood: 200_000 stones, a half-length ward — O(n*k) times out,
// the sliding window (one pass) does not.
let flood = vec![1_i64; 200_000];
assert_eq!(strongest_ward(&flood, 100_000), 100_000, "TRIAL: the flooded ward miscounted");"#,
            hints: [
                "Re-summing each window repeats almost all the work. Reuse the previous window's sum.",
                "Sum the first `k`. Then for each next window, `sum += stones[i] - stones[i - k]` and track the best.",
                "let mut sum: i64 = stones[..k].iter().sum(); let mut best = sum; for i in k..stones.len() { sum += stones[i] - stones[i - k]; best = best.max(sum); } best",
            ],
            toolbox: [
                "sliding window",
                "sum += entering - leaving",
                "slice[..k].iter().sum()",
            ],
            solution: r#"fn strongest_ward(stones: &[i64], k: usize) -> i64 {
    let mut sum: i64 = stones[..k].iter().sum();
    let mut best = sum;
    for i in k..stones.len() {
        sum += stones[i] - stones[i - k];
        best = best.max(sum);
    }
    best
}
"#,
        ),
        (
            id: "ad-03-the-mirror-hall",
            title: "The Mirror Hall",
            scene: "The hall of runes must be reversed to read the true word — and the dungeon forbids conjuring a second hall: reverse the runes IN PLACE, using no new collection, only swaps.\n\nThe spell below builds a reversed copy and lets it vanish, leaving the caller's runes untouched. Two fingers, one at each end, swapping inward until they meet — that is the whole trick, and it borrows no extra space.",
            concepts: [Algorithms],
            starter_code: r#"fn reverse_runes(runes: &mut Vec<i32>) {
    // This conjures a NEW reversed vec and drops it — the caller's
    // runes never change. Reverse in place: swap the ends inward with
    // two indices walking toward each other. No new collection.
    let _reversed: Vec<i32> = runes.iter().rev().cloned().collect();
}
"#,
            trial: r#"let mut a = vec![1, 2, 3, 4, 5];
reverse_runes(&mut a);
assert_eq!(a, vec![5, 4, 3, 2, 1], "TRIAL: the runes were not reversed");
let mut b = vec![9];
reverse_runes(&mut b);
assert_eq!(b, vec![9], "TRIAL: a single rune must survive unchanged");
let mut c: Vec<i32> = vec![];
reverse_runes(&mut c);
assert_eq!(c, Vec::<i32>::new(), "TRIAL: an empty hall must stay empty");"#,
            hints: [
                "You already hold `&mut` — mutate it directly instead of building a new vec.",
                "Two indices: one at 0, one at len-1. Swap them, step inward, stop when they meet.",
                "let (mut i, mut j) = (0, runes.len().saturating_sub(1)); while i < j { runes.swap(i, j); i += 1; j -= 1; }",
            ],
            toolbox: [
                "&mut Vec<i32>",
                "slice::swap",
                "two-pointer (i, j) inward",
            ],
            solution: r#"fn reverse_runes(runes: &mut Vec<i32>) {
    let (mut i, mut j) = (0, runes.len().saturating_sub(1));
    while i < j {
        runes.swap(i, j);
        i += 1;
        j -= 1;
    }
}
"#,
        ),
        (
            id: "ad-04-the-toll-of-spans",
            title: "The Toll of Spans",
            scene: "The keeper asks the sum of many SPANS of a long tally — a flurry of `(left, right)` questions. The spell answers each by re-adding the span: with a hundred thousand spans over a hundred thousand values, that is ten billion additions, and the toll times out.\n\nBuild a prefix-sum table ONCE — running totals from the start — and every span becomes a single subtraction: `prefix[right+1] − prefix[left]`.",
            concepts: [Algorithms, Collections],
            starter_code: r#"fn span_tolls(tally: &[i64], spans: &[(usize, usize)]) -> Vec<i64> {
    // Correct — and O(spans * span_len): each question re-adds its
    // whole span. The flood asks 100_000 wide spans; it times out.
    // Precompute prefix sums once, then answer each span by subtraction.
    spans
        .iter()
        .map(|&(l, r)| tally[l..=r].iter().sum())
        .collect()
}
"#,
            trial: r#"assert_eq!(
    span_tolls(&[1, 2, 3, 4], &[(0, 1), (1, 3)]),
    vec![3, 9],
    "TRIAL: a span was tolled wrong"
);
// The flood: 100_000 ones, and 100_000 questions each spanning the
// whole tally. Re-adding is ~10 billion ops; prefix sums answer O(1).
let tally = vec![1_i64; 100_000];
let spans = vec![(0usize, 99_999usize); 100_000];
let tolls = span_tolls(&tally, &spans);
assert_eq!(tolls.len(), 100_000, "TRIAL: a question went unanswered");
assert_eq!(tolls[0], 100_000, "TRIAL: the full span was mistolled");"#,
            hints: [
                "Every span recomputes overlapping work. Precompute running totals once.",
                "Build `prefix` where `prefix[i]` is the sum of the first `i` values; then a span (l, r) is `prefix[r + 1] - prefix[l]`.",
                "let mut prefix = vec![0i64; tally.len() + 1]; for i in 0..tally.len() { prefix[i + 1] = prefix[i] + tally[i]; } … spans.iter().map(|&(l, r)| prefix[r + 1] - prefix[l]).collect()",
            ],
            toolbox: [
                "prefix sums (build once)",
                "prefix[r+1] - prefix[l]",
                ".map().collect()",
            ],
            solution: r#"fn span_tolls(tally: &[i64], spans: &[(usize, usize)]) -> Vec<i64> {
    let mut prefix = vec![0i64; tally.len() + 1];
    for i in 0..tally.len() {
        prefix[i + 1] = prefix[i] + tally[i];
    }
    spans
        .iter()
        .map(|&(l, r)| prefix[r + 1] - prefix[l])
        .collect()
}
"#,
        ),
        (
            id: "ad-05-the-deepest-vein",
            title: "The Deepest Vein",
            scene: "The vault's heart: find the richest contiguous vein of ore — the maximum sum of any run of consecutive values, even when some are negative. The spell tries every start and every end: O(n²), and the flood buries it.\n\nOne pass suffices (Kadane's insight): at each stone, the best run ending HERE is either this stone alone or this stone joined to the best run ending just before it — `max(x, running + x)`. Track the best ever seen.\n\nThe deepest vein, in a single sweep. Leave alive.",
            concepts: [Algorithms],
            starter_code: r#"fn deepest_vein(ore: &[i64]) -> i64 {
    // Correct — and O(n^2): every (start, end) run is summed. The
    // flood of 150_000 values buries it. One pass is enough: the best
    // run ending here is max(x, running_so_far + x).
    let mut best = i64::MIN;
    for i in 0..ore.len() {
        let mut run = 0;
        for &x in &ore[i..] {
            run += x;
            best = best.max(run);
        }
    }
    best
}
"#,
            trial: r#"assert_eq!(
    deepest_vein(&[-2, 1, -3, 4, -1, 2, 1, -5, 4]),
    6,
    "TRIAL: the richest vein was misjudged"
);
assert_eq!(deepest_vein(&[-8, -3, -5]), -3, "TRIAL: all-negative must pick the least loss");
// The flood: 150_000 values; O(n^2) is ~11 billion adds and times out.
let flood = vec![1_i64; 150_000];
assert_eq!(deepest_vein(&flood), 150_000, "TRIAL: the flooded vein miscounted");"#,
            hints: [
                "Re-summing every run repeats work. Carry the best run ending at the current stone as you sweep.",
                "Kadane: `run = x.max(run + x)` at each value; the answer is the largest `run` seen. Start both from the first value.",
                "let mut run = ore[0]; let mut best = ore[0]; for &x in &ore[1..] { run = x.max(run + x); best = best.max(run); } best",
            ],
            toolbox: [
                "Kadane's algorithm",
                "run = x.max(run + x)",
                "track best-so-far",
            ],
            solution: r#"fn deepest_vein(ore: &[i64]) -> i64 {
    let mut run = ore[0];
    let mut best = ore[0];
    for &x in &ore[1..] {
        run = x.max(run + x);
        best = best.max(run);
    }
    best
}
"#,
        ),
    ],
)
